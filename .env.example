# GitHub Actions Secrets - Add these in GitHub repo settings
N8N_WEBHOOK_URL=https://n8napp.adamj.fit/webhook/avalimo-deploy

# Optional - if using Coolify webhook triggers
COOLIFY_STAGING_WEBHOOK=
COOLIFY_PRODUCTION_WEBHOOK=

# n8n Configuration
N8N_HOST=n8napp.adamj.fit
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id_from_userinfobot

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_USER=adam@avalimo.net
SMTP_PASS=your_app_password

# Google Search Console (after verification)
GSC_VERIFICATION=your_verification_code

# Facebook Pixel (after setup)
FB_PIXEL_ID=your_pixel_id
